; Loupe — Godot 4.7 project (typed GDScript)
; Engine configuration file. See https://docs.godotengine.org/

config_version=5

[application]

config/name="Loupe"
config/description="Native holographic, domain-agnostic exploded-view explorer."
run/main_scene="res://src/main/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

IntentBus="*res://src/intent/intent_bus.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/per_pixel_transparency/allowed=false

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.02, 0.03, 0.05, 1)
anti_aliasing/quality/msaa_3d=2
